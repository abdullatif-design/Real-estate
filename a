        ["Verify & Unlock Data Room", "تحقق وافتح غرفة البيانات"],
        ["Return to details", "العودة إلى البيانات"]
      ]);

      const placeholders = new Map([
        ["Your full name", "الاسم الثلاثي"],
        ["Organization", "اسم الجهة"],
        ["name@company.com", "name@company.com"],
        ["+966 5X XXX XXXX", "+966 5X XXX XXXX"]
      ]);
      const ariaTranslations = new Map([
        ["Primary navigation", "التنقل الرئيسي"],
        ["Premium Real Estate Investment home", "الرئيسية للاستثمار العقاري النوعي"],
        ["Conceptual architectural massing visualization", "تصور معماري مبدئي للمشروع"],
        ["Play conceptual project film", "تشغيل الفيلم التصوري للمشروع"],
        ["Abstract strategic location map", "خريطة تجريدية للموقع الاستراتيجي"],
        ["Close access form", "إغلاق نموذج الدخول"],
        ["Four-digit access code", "رمز دخول من أربعة أرقام"],
        ["Slide navigation", "التنقل بين السلايدات"],
        ["Previous slide", "السلايد السابق"],
        ["Next slide", "السلايد التالي"]
      ]);

      const textNodes = [];
      const walker = document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT);
      let node;
      while ((node = walker.nextNode())) {
        if (node.parentElement && !["SCRIPT", "STYLE"].includes(node.parentElement.tagName) && node.nodeValue.trim()) {
          textNodes.push({ node, original: node.nodeValue });
        }
      }
      const translatableInputs = [...document.querySelectorAll("input[placeholder]")].map(input => ({
        input,
        original: input.placeholder
      }));
      const translatableAria = [...document.querySelectorAll("[aria-label]")].map(element => ({
        element,
        original: element.getAttribute("aria-label")
      }));

      const applyLanguage = language => {
        const isArabic = language === "ar";
        document.documentElement.lang = language;
        document.documentElement.dir = isArabic ? "rtl" : "ltr";
        document.title = isArabic ? "ممر نمو الرياض | فرصة استثمارية نوعية" : "Riyadh Growth Corridor | Premium Investment Opportunity";
        document.querySelector('meta[name="description"]').content = isArabic
          ? "فرصة استثمار عقاري مؤسسية وسرية في ممر النمو بمدينة الرياض."
          : "Confidential institutional real estate investment opportunity in Riyadh's growth corridor.";

        textNodes.forEach(({ node, original }) => {
          const trimmed = original.trim();
          if (!isArabic || !translations.has(trimmed)) {
            node.nodeValue = original;
            return;
          }
          const leading = original.match(/^\s*/)[0];
          const trailing = original.match(/\s*$/)[0];
          node.nodeValue = leading + translations.get(trimmed) + trailing;
        });
        translatableInputs.forEach(({ input, original }) => {
          input.placeholder = isArabic ? (placeholders.get(original) || original) : original;
        });
        translatableAria.forEach(({ element, original }) => {
          element.setAttribute("aria-label", isArabic ? (ariaTranslations.get(original) || original) : original);
        });

        const languageToggle = document.getElementById("language-toggle");
        languageToggle.textContent = isArabic ? "EN" : "ع";
        languageToggle.setAttribute("aria-label", isArabic ? "Switch to English" : "التبديل إلى العربية");
        languageToggle.title = isArabic ? "Switch to English" : "التبديل إلى العربية";
        localStorage.setItem("preferredLanguage", language);
      };

      const modal = document.getElementById("access-modal");
      const formStep = document.getElementById("form-step");
      const otpStep = document.getElementById("otp-step");
      const accessForm = document.getElementById("access-form");
      const otpForm = document.getElementById("otp-form");
      const formError = document.getElementById("form-error");
      const otpError = document.getElementById("otp-error");
      const otpCode = document.getElementById("otp-code");
      const dataRoom = document.getElementById("data-room");
      const slideDots = document.getElementById("slide-dots");
      const slideCounter = document.getElementById("slide-counter");
      const previousSlide = document.getElementById("previous-slide");
      const nextSlide = document.getElementById("next-slide");
      let lastFocusedElement = null;
      let slides = [];
      let activeSlideIndex = 0;
      let isTransitioning = false;
      let queuedSlideIndex = null;
      let wheelLocked = false;
      let touchStartY = 0;

      const formatSlideNumber = number => String(number).padStart(2, "0");

      const setActiveSlide = index => {
        if (!slides.length) return;
        activeSlideIndex = Math.max(0, Math.min(index, slides.length - 1));
        slides.forEach((slide, slideIndex) => {
          const isActive = slideIndex === activeSlideIndex;
          slide.classList.toggle("slide-active", isActive);
          slide.classList.toggle("slide-before", slideIndex < activeSlideIndex);
          slide.classList.toggle("slide-after", slideIndex > activeSlideIndex);
          slide.setAttribute("aria-hidden", isActive ? "false" : "true");
        });
        [...slideDots.children].forEach((dot, dotIndex) => {
          const isActive = dotIndex === activeSlideIndex;
          dot.classList.toggle("is-active", isActive);
          dot.setAttribute("aria-current", isActive ? "true" : "false");
        });
        slideCounter.textContent = `${formatSlideNumber(activeSlideIndex + 1)} / ${formatSlideNumber(slides.length)}`;
        previousSlide.disabled = activeSlideIndex === 0;
        nextSlide.disabled = activeSlideIndex === slides.length - 1;
      };

      const scrollToSlide = index => {
        if (!slides[index] || index === activeSlideIndex) return;
        if (isTransitioning) {
          queuedSlideIndex = index;
          return;
        }
        isTransitioning = true;
        setActiveSlide(index);
        slides[index].scrollTo({ top: 0, behavior: "smooth" });
        setTimeout(() => {
          isTransitioning = false;
          if (queuedSlideIndex !== null && queuedSlideIndex !== activeSlideIndex) {
            const nextIndex = queuedSlideIndex;
            queuedSlideIndex = null;
            scrollToSlide(nextIndex);
          } else {
            queuedSlideIndex = null;
          }
        }, 760);
      };

      const refreshSlides = () => {
        slides = [...document.querySelectorAll(".slide-section")].filter(slide => !slide.classList.contains("hidden"));
        slideDots.innerHTML = "";
        slides.forEach((slide, index) => {
          const dot = document.createElement("button");
          dot.type = "button";
          dot.className = "slide-dot";
          const isArabic = document.documentElement.lang === "ar";
          dot.setAttribute("aria-label", isArabic ? `انتقل إلى السلايد ${index + 1}` : `Go to slide ${index + 1}`);
          dot.addEventListener("click", () => scrollToSlide(index));
          slideDots.appendChild(dot);
        });
        setActiveSlide(Math.min(activeSlideIndex, slides.length - 1));
      };

      previousSlide.addEventListener("click", () => scrollToSlide(activeSlideIndex - 1));
      nextSlide.addEventListener("click", () => scrollToSlide(activeSlideIndex + 1));
      document.querySelectorAll("[data-slide-target]").forEach(link => {
        link.addEventListener("click", event => {
          event.preventDefault();
          const target = document.getElementById(link.dataset.slideTarget);
          scrollToSlide(slides.indexOf(target));
        });
      });

      document.addEventListener("wheel", event => {
        if (!modal.classList.contains("hidden") || wheelLocked || isTransitioning || Math.abs(event.deltaY) < 20) return;
        const activeSlide = slides[activeSlideIndex];
        if (!activeSlide) return;
        const atTop = activeSlide.scrollTop <= 2;
        const atBottom = activeSlide.scrollTop + activeSlide.clientHeight >= activeSlide.scrollHeight - 2;
        const direction = event.deltaY > 0 ? 1 : -1;
        if ((direction > 0 && !atBottom) || (direction < 0 && !atTop)) return;
        const targetIndex = activeSlideIndex + direction;
        if (!slides[targetIndex]) return;
        event.preventDefault();
        wheelLocked = true;
        scrollToSlide(targetIndex);
        setTimeout(() => { wheelLocked = false; }, 780);
      }, { passive: false });

      document.addEventListener("touchstart", event => {
        touchStartY = event.changedTouches[0].clientY;
      }, { passive: true });

      document.addEventListener("touchend", event => {
        if (!modal.classList.contains("hidden")) return;
        const distance = touchStartY - event.changedTouches[0].clientY;
        if (Math.abs(distance) < 70) return;
        if (window.matchMedia("(max-width: 767px)").matches) {
          scrollToSlide(activeSlideIndex + (distance > 0 ? 1 : -1));
          return;
        }
        const activeSlide = slides[activeSlideIndex];
        const atTop = activeSlide.scrollTop <= 2;
        const atBottom = activeSlide.scrollTop + activeSlide.clientHeight >= activeSlide.scrollHeight - 2;
        if (distance > 0 && atBottom) scrollToSlide(activeSlideIndex + 1);
        if (distance < 0 && atTop) scrollToSlide(activeSlideIndex - 1);
      }, { passive: true });

      document.getElementById("language-toggle").addEventListener("click", () => {
        applyLanguage(document.documentElement.lang === "ar" ? "en" : "ar");
        refreshSlides();
      });

      const openModal = () => {
        lastFocusedElement = document.activeElement;
        modal.classList.remove("hidden");
        modal.classList.add("flex");
        document.body.style.overflow = "hidden";
        setTimeout(() => document.getElementById("full-name").focus(), 50);
      };

      const closeModal = () => {
        modal.classList.add("hidden");
        modal.classList.remove("flex");
        document.body.style.overflow = "";
        if (lastFocusedElement) lastFocusedElement.focus();
      };

      document.querySelectorAll("[data-open-modal]").forEach(button => button.addEventListener("click", openModal));
      document.querySelectorAll("[data-close-modal]").forEach(element => element.addEventListener("click", closeModal));
      document.getElementById("close-modal").addEventListener("click", closeModal);

      accessForm.addEventListener("submit", event => {
        event.preventDefault();
        const fields = ["full-name", "company", "email", "phone"];
        const valuesComplete = fields.every(id => document.getElementById(id).value.trim());
        const emailValid = document.getElementById("email").checkValidity();
        const ndaAccepted = document.getElementById("nda").checked;

        if (!valuesComplete || !emailValid || !ndaAccepted) {
          formError.classList.remove("hidden");
          return;
        }

        formError.classList.add("hidden");
        formStep.classList.add("hidden");
        otpStep.classList.remove("hidden");
        setTimeout(() => otpCode.focus(), 50);
      });

      otpForm.addEventListener("submit", event => {
        event.preventDefault();
        if (otpCode.value.trim() !== "1234") {
          otpError.classList.remove("hidden");
          otpCode.focus();
          otpCode.select();
          return;
        }

        otpError.classList.add("hidden");
        dataRoom.classList.remove("hidden");
        refreshSlides();
        closeModal();
        setTimeout(() => scrollToSlide(slides.indexOf(dataRoom)), 100);
      });

      document.getElementById("back-to-form").addEventListener("click", () => {
        otpStep.classList.add("hidden");
        formStep.classList.remove("hidden");
        otpCode.value = "";
        otpError.classList.add("hidden");
        setTimeout(() => document.getElementById("full-name").focus(), 50);
      });

      document.addEventListener("keydown", event => {
        if (event.key === "Escape" && !modal.classList.contains("hidden")) closeModal();
        if (!modal.classList.contains("hidden") || ["INPUT", "TEXTAREA", "SELECT"].includes(document.activeElement.tagName)) return;
        if (["ArrowDown", "PageDown"].includes(event.key)) {
          event.preventDefault();
          scrollToSlide(activeSlideIndex + 1);
        }
        if (["ArrowUp", "PageUp"].includes(event.key)) {
          event.preventDefault();
          scrollToSlide(activeSlideIndex - 1);
        }
      });

      applyLanguage(localStorage.getItem("preferredLanguage") || "ar");
      refreshSlides();
    })();
  </script>


